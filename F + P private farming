-- Helper function to get player's HRP safely
local function getHRP()
    local char = game.Players.LocalPlayer.Character
    if char then
        return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
    end
    return nil
end

-- Improved teleport function (handles dot paths like "TrainingAreas.Fridge.Part")
local function teleportToPath(pathStr)
    local hrp = getHRP()
    if not hrp then
        warn("No character / HRP found!")
        return
    end
    
    local current = workspace
    for part in string.gmatch(pathStr, "[^.]+") do
        current = current:FindFirstChild(part)
        if not current then
            warn("Path not found: " .. pathStr)
            return
        end
    end
    
    -- If we reached a valid part/model, teleport to its primary CFrame or Position + offset
    local targetCFrame
    if current:IsA("Model") and current.PrimaryPart then
        targetCFrame = current.PrimaryPart.CFrame
    elseif current:IsA("BasePart") then
        targetCFrame = current.CFrame
    else
        targetCFrame = CFrame.new(current.Position + Vector3.new(0, 5, 0)) -- fallback
    end
    
    hrp.CFrame = targetCFrame + Vector3.new(0, 3, 0) -- slight offset to avoid clipping
    print("Teleported to: " .. pathStr)
end

-- Fallback teleport by name search (useful if exact path fails in updated game)
local function teleportToName(name)
    local hrp = getHRP()
    if not hrp then return end
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == name and (obj:IsA("BasePart") or (obj:IsA("Model") and obj.PrimaryPart)) then
            local cf = obj:IsA("BasePart") and obj.CFrame or obj.PrimaryPart.CFrame
            hrp.CFrame = cf + Vector3.new(0, 5, 0)
            print("Teleported to object named: " .. name)
            return
        end
    end
    warn("No object found with name: " .. name)
end

